{
  "name": "douluo-spin",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3005",
    "build": "vue-tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "test": "vitest run tests",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:verify": "npm test && npm run build && npm run test:e2e"
  },
  "dependencies": {
    "lucide-vue-next": "^0.544.0",
    "vue": "^3.5.21"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.5.2",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "typescript": "~5.9.2",
    "vite": "^7.1.7",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.0.8"
  }
}
